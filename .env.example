# AI4SE Coding Agent Harness — 环境变量模板
# 复制为 .env 并填入你的凭据

# LLM Provider: "openai" | "local" | "mock"
LLM_PROVIDER=openai

# OpenAI 兼容 API
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://your-api-endpoint.example.com/v1
OPENAI_MODEL=your-model-name

# 本地模型（OpenAI 兼容格式）
LOCAL_MODEL_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=your-local-model